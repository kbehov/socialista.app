{
  "name": "@socialista/trigger",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shared Trigger.dev background tasks for Socialista",
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsc -p tsconfig.check.json",
    "check-types": "tsc -p tsconfig.check.json",
    "dev:trigger": "trigger dev",
    "deploy:trigger": "trigger deploy"
  },
  "exports": {
    ".": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    },
    "./schemas/image-generation": {
      "types": "./src/schemas/image-generation.schema.ts",
      "import": "./src/schemas/image-generation.schema.ts"
    },
    "./schemas/static-ad": {
      "types": "./src/schemas/static-ad.schema.ts",
      "import": "./src/schemas/static-ad.schema.ts"
    },
    "./schemas/refresh-account-token": {
      "types": "./src/schemas/refresh-account-token.schema.ts",
      "import": "./src/schemas/refresh-account-token.schema.ts"
    },
    "./schemas/publish-post": {
      "types": "./src/schemas/publish-post.schema.ts",
      "import": "./src/schemas/publish-post.schema.ts"
    },
    "./task-types": {
      "types": "./src/task-types.ts",
      "import": "./src/task-types.ts"
    }
  },
  "license": "ISC",
  "dependencies": {
    "@socialista/db": "workspace:^",
    "@socialista/types": "workspace:^",
    "@fal-ai/client": "^1.10.1",
    "@trigger.dev/sdk": "^4.5.3",
    "ai": "^6.0.208",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@socialista/eslint-config": "workspace:^",
    "@socialista/typescript-config": "workspace:^",
    "@trigger.dev/build": "^4.5.3",
    "@types/node": "^25.9.3",
    "eslint": "^9.39.1",
    "trigger.dev": "^4.5.3",
    "typescript": "^6.0.3"
  }
}
