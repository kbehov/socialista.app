{
  "name": "socialista.app",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "build:db": "turbo run build --filter=@socialista/db",
    "lint:db": "turbo run lint --filter=@socialista/db",
    "check-types:db": "turbo run check-types --filter=@socialista/db",
    "start:api": "turbo run start --filter=@socialista/api",
    "dev:api": "turbo run dev --filter=@socialista/api",
    "lint:api": "turbo run lint --filter=@socialista/api",
    "build:api": "turbo run build --filter=@socialista/api",
    "dev:web": "turbo run dev --filter=@socialista/web",
    "build:types": "turbo run build --filter=@socialista/types",
    "check-types:api": "turbo run check-types --filter=@socialista/api",
    "dev:trigger": "turbo run dev:trigger --filter=@socialista/trigger",
    "deploy:trigger": "turbo run deploy:trigger --filter=@socialista/trigger",
    "lint:trigger": "turbo run lint --filter=@socialista/trigger",
    "check-types:trigger": "turbo run check-types --filter=@socialista/trigger",
    "clean": "pnpm exec turbo run clean 2>/dev/null || true && rm -rf node_modules .pnpm-store .turbo",
    "clean:all": "rm -rf node_modules apps/*/node_modules packages/*/node_modules .pnpm-store .turbo",
    "clean:lock": "rm -rf pnpm-lock.yaml"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.4",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=18"
  }
}
